{
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 1 },
    "sources_added": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string" },
          "type": { "type": "string", "enum": ["Primary", "Fact", "Opinion", "Data"] },
          "updated_at": { "type": "string" },
          "relevance": { "type": "string" },
          "takeaways": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": { "type": "string" }
          }
        },
        "required": ["title", "url", "type", "updated_at", "relevance", "takeaways"],
        "additionalProperties": false
      }
    },
    "candidate_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "source_urls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "required": ["claim", "why_it_matters", "source_urls"],
        "additionalProperties": false
      }
    },
    "unresolved_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "why_unresolved": { "type": "string" },
          "suggested_next_step": { "type": "string" }
        },
        "required": ["question", "why_it_matters", "why_unresolved", "suggested_next_step"],
        "additionalProperties": false
      }
    }
  },
  "required": ["run_id", "round", "sources_added", "candidate_claims", "unresolved_gaps"],
  "additionalProperties": false
}
