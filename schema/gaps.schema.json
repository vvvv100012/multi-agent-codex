{
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 1 },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] },
          "affected_question_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_urls": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fix": { "type": "string" }
        },
        "required": ["issue", "severity", "affected_question_ids", "evidence_urls", "fix"],
        "additionalProperties": false
      }
    },
    "missing_proof": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "why_unresolved": { "type": "string" },
          "suggested_next_step": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        },
        "required": [
          "question",
          "why_it_matters",
          "why_unresolved",
          "suggested_next_step",
          "severity"
        ],
        "additionalProperties": false
      }
    },
    "next_queries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "continue_research": { "type": "boolean" },
    "stop_reason": { "type": "string" }
  },
  "required": [
    "run_id",
    "round",
    "contradictions",
    "missing_proof",
    "next_queries",
    "continue_research",
    "stop_reason"
  ],
  "additionalProperties": false
}
