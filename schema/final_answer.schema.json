{
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "report_mode": {
      "type": "string",
      "enum": ["management_brief", "internal_share"]
    },
    "title": { "type": "string" },
    "decision_or_discussion_need": { "type": "string" },
    "summary": { "type": "string" },
    "top_takeaways": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "type": "string" }
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "heading": { "type": "string" },
          "thesis": { "type": "string" },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": { "type": "string" }
          },
          "key_metrics": {
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" },
                "why_it_matters": { "type": "string" }
              },
              "required": ["label", "value", "why_it_matters"],
              "additionalProperties": false
            }
          },
          "evidence_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["heading", "thesis", "paragraphs", "key_metrics", "evidence_ids"],
        "additionalProperties": false
      }
    },
    "open_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "run_id",
    "report_mode",
    "title",
    "decision_or_discussion_need",
    "summary",
    "top_takeaways",
    "sections",
    "open_gaps",
    "next_actions"
  ],
  "additionalProperties": false
}
