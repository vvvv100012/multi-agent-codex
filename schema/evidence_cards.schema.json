{
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "round": { "type": "integer", "minimum": 1 },
    "evidence_cards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "question_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verdict": {
            "type": "string",
            "enum": ["supported", "contradicted", "mixed", "insufficient"]
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "answer_relevance": {
            "type": "string",
            "enum": ["core", "supporting", "context"]
          },
          "as_of": { "type": "string" },
          "metric_definition": { "type": "string" },
          "source_urls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "required": [
          "claim",
          "question_ids",
          "verdict",
          "confidence",
          "answer_relevance",
          "as_of",
          "metric_definition",
          "source_urls",
          "notes"
        ],
        "additionalProperties": false
      }
    },
    "unresolved_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "why_unresolved": { "type": "string" },
          "suggested_next_step": { "type": "string" }
        },
        "required": ["question", "why_it_matters", "why_unresolved", "suggested_next_step"],
        "additionalProperties": false
      }
    }
  },
  "required": ["run_id", "round", "evidence_cards", "unresolved_gaps"],
  "additionalProperties": false
}
