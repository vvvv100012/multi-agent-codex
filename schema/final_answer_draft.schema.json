{
  "type": "object",
  "properties": {
    "run_id": {
      "type": "string"
    },
    "report_mode": {
      "type": "string",
      "enum": [
        "management_brief",
        "internal_share"
      ]
    },
    "analysis_depth": {
      "type": "string",
      "enum": [
        "standard",
        "deep"
      ]
    },
    "title": {
      "type": "string"
    },
    "decision_or_discussion_need": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "top_takeaways": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "heading": {
            "type": "string"
          },
          "thesis": {
            "type": "string"
          },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": {
              "type": "string"
            }
          },
          "key_metrics": {
            "type": "array",
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                },
                "why_it_matters": {
                  "type": "string"
                }
              },
              "required": [
                "label",
                "value",
                "why_it_matters"
              ],
              "additionalProperties": false
            }
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "analysis_moves": {
            "type": "object",
            "properties": {
              "what_the_data_says": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "interpretation": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "alternative_explanations_or_limits": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "implication_or_discussion_hook": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "what_the_data_says",
              "interpretation",
              "alternative_explanations_or_limits",
              "implication_or_discussion_hook"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "heading",
          "thesis",
          "paragraphs",
          "key_metrics",
          "evidence_ids",
          "analysis_moves"
        ],
        "additionalProperties": false
      }
    },
    "working_hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "hypothesis": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "enum": [
              "supported_inference",
              "plausible_hypothesis"
            ]
          },
          "why_plausible": {
            "type": "string"
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "gap_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "what_would_change_my_mind": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "hypothesis",
          "label",
          "why_plausible",
          "evidence_ids",
          "gap_ids",
          "confidence",
          "what_would_change_my_mind"
        ],
        "additionalProperties": false
      }
    },
    "discussion_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "what_would_change_our_mind": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "watch_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "run_id",
    "report_mode",
    "analysis_depth",
    "title",
    "decision_or_discussion_need",
    "summary",
    "top_takeaways",
    "sections",
    "working_hypotheses",
    "discussion_questions",
    "what_would_change_our_mind",
    "watch_items",
    "open_gaps",
    "next_actions"
  ],
  "additionalProperties": false
}
